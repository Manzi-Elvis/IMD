# Copy to .env and fill in real values. Never commit the actual .env.
NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=incident_app
DB_PASSWORD=change_me
DB_NAME=incident_management
DB_SYNCHRONIZE=false
DB_SSL=false

